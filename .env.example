# Here Comes The Bus Credentials
HCTB_EMAIL=your_email@example.com
HCTB_PASSWORD=your_password
HCTB_SCHOOL_CODE=12345

# School GPS Coordinates (right-click on Google Maps to get these)
SCHOOL_LAT=35.12345
SCHOOL_LON=-80.12345

# Notification radius in miles
NOTIFICATION_RADIUS_MILES=2.0

# How often to check bus location (in seconds, min 30 recommended)
POLL_INTERVAL_SECONDS=60

# VAPID Keys for Web Push (generate with: python generate_vapid.py)
VAPID_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
VAPID_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
VAPID_CLAIM_EMAIL=mailto:your@email.com
